params {
    user = ""
    account = ""
    job_name = "pyfraglib-nf"
    work_dir = ""
    log_dir = ""
    out_dir = ""

    sample_tbl = "example_sample_sheet.tsv"

    // @NOTE(ds): Must be indexed and compressed (`pysam' requirement).
    bed_file = ""
    gmm_config_file = ""

    // @NOTE(ds): The following parameters facilitate debugging. When set to
    // `true' at the command line, they will force the corresponding group of
    // processes to be executed even if results are already cached and
    // `-resume' is set.
    force_stage_data = false // sufficient to force everything
    force_extract = false
    force_stats = false
    force_lengths = false
    force_scores = false
}

workDir = "${params.work_dir}"

process {
    withLabel: "serial" {
        cpus = 2
        memory = 24.GB
    }
    withLabel: "parallel" {
        cpus = 8
        memory = 64.GB
    }
    withLabel: "huge_mem" {
        cpus = 8
        memory = 128.GB
    }
}

profiles {
    your_cluster {
        process.executor = "slurm"
        process.queue = "smp"
        process.clusterOptions = "--mail-user='${params.user}@<domain>' --mail-type=NONE -e ${params.log_dir}/${params.job_name}_%j.err -o ${params.log_dir}/${params.job_name}_%j.out"
        executor {
            account = "${params.account}"
            jobName = "${params.job_name}"
        }
        params.conda_env = ""
    }
    workstation {
        process.executor = "local"
        params.conda_env = "pyfraglib"
    }
}
