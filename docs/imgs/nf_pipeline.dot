digraph Nextflow_Pipeline {
    rankdir=LR;
    // > bgcolor="transparent";

    subgraph cluster_individual {
        label="Parallel Processing";
        style=solid;
        fontsize=14;

        C1 [label=<extract BAM<SUB>1</SUB>>];
        C2 [label=<extract BAM<SUB>2</SUB>>];
        Ci [label=<extract BAM<SUB>i</SUB>>,fontcolor=gray,color=gray,style=dashed];
        Cn [label=<extract BAM<SUB>n</SUB>>];

        D1 [label=<process FRAG<SUB>1</SUB>>];
        D2 [label=<process FRAG<SUB>2</SUB>>];
        Di [label=<process FRAG<SUB>i</SUB>>,fontcolor=gray,color=gray,style=dashed];
        Dn [label=<process FRAG<SUB>n</SUB>>];

        E1 [label=<save results<SUB>1</SUB>>];
        E2 [label=<save results<SUB>2</SUB>>];
        Ei [label=<save results<SUB>i</SUB>>,fontcolor=gray,color=gray,style=dashed];
        En [label=<save results<SUB>n</SUB>>];

        C1 -> D1 -> E1;
        C2 -> D2 -> E2;
        Ci -> Di -> Ei [fontcolor=gray,color=gray,style=dashed];
        Cn -> Dn -> En;
    }

    F [label="NMF &\nDifferential\nEnd Motifs",shape=box,fontsize=12];
    G [label="Cohort\nWide\nResults",shape=box,fontsize=12];

    A -> B [label="nextflow run",fontcolor=darkred,style=bold];
    B -> C1;
    B -> C2;
    B -> Ci [color=gray,style=dashed];
    B -> Cn;

    E1 -> F [style=bold];
    E2 -> F [style=bold];
    Ei -> F [fontcolor=gray,color=gray,style=dashed];
    En -> F [style=bold];
    F -> G [style=bold];

    A [label=<Sample Sheet<BR/>(<I>n</I> samples)>,shape=box,fontsize=14];
    B [label="Nextflow\nOrchestrator",shape=circle,fontsize=12];
}
